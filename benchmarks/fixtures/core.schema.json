{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "NeSy Reasoning Offline Benchmark Fixture",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "name", "cases"],
  "properties": {
    "version": { "type": "string" },
    "name": { "type": "string", "minLength": 1 },
    "cases": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/case" }
    }
  },
  "$defs": {
    "case": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "category",
        "description",
        "relation_set",
        "tool_name",
        "tool_input",
        "expected",
        "baselines"
      ],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9_\\-]+$" },
        "category": {
          "type": "string",
          "enum": [
            "classification",
            "transitive",
            "contradiction",
            "counterfactual",
            "business"
          ]
        },
        "description": { "type": "string", "minLength": 1 },
        "relation_set": { "type": "object" },
        "tool_name": { "type": "string", "pattern": "^nesy\\." },
        "tool_input": { "type": "object" },
        "expected": {
          "type": "object",
          "additionalProperties": false,
          "anyOf": [
            { "required": ["equals"] },
            { "required": ["contains"] },
            { "required": ["min_count"] }
          ],
          "properties": {
            "equals": {
              "type": "object",
              "minProperties": 1,
              "additionalProperties": true
            },
            "contains": {
              "type": "object",
              "minProperties": 1,
              "additionalProperties": true
            },
            "min_count": {
              "type": "object",
              "minProperties": 1,
              "additionalProperties": {
                "type": "integer",
                "minimum": 0
              }
            }
          }
        },
        "baselines": {
          "type": "object",
          "additionalProperties": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          }
        }
      }
    }
  }
}
