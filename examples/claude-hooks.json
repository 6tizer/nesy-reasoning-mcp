{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|Edit|Write|Read|Grep|Glob|WebSearch|WebFetch|mcp__nesy-reasoning__.*",
        "hooks": [
          {
            "type": "command",
            "command": "NESY_CONFIG=~/.nesy-reasoning/nesy-config.json uv --directory /path/to/nesy-reasoning-mcp run nesy-reasoning-mcp hook pretooluse"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "NESY_CONFIG=~/.nesy-reasoning/nesy-config.json uv --directory /path/to/nesy-reasoning-mcp run nesy-reasoning-mcp hook stop"
          }
        ]
      }
    ]
  }
}
